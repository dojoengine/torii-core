#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

resolve_pnpm() {
  if command -v pnpm >/dev/null 2>&1; then
    command -v pnpm
    return 0
  fi

  if command -v corepack >/dev/null 2>&1; then
    echo "corepack pnpm"
    return 0
  fi

  if [ -x "$HOME/.local/share/pnpm/pnpm" ]; then
    echo "$HOME/.local/share/pnpm/pnpm"
    return 0
  fi

  return 1
}

PNPM_CMD="$(resolve_pnpm)" || {
  echo "pnpm is required for the pre-commit hook but was not found." >&2
  echo "Install pnpm or ensure corepack is available on PATH." >&2
  exit 1
}

if [ -z "$(git diff --cached --name-only)" ]; then
  exit 0
fi

if [ -n "$(git diff --name-only)" ] || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  echo "pre-commit requires a clean working tree." >&2
  echo "Stage or stash tracked changes and remove untracked files before committing." >&2
  exit 1
fi

$PNPM_CMD run lint:check
